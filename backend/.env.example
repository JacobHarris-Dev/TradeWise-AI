ML_MODEL_VERSION=dev
ML_MODEL_ARTIFACT=artifacts/tradewise_model.pkl
ML_MODEL_ARTIFACT_SAFE=artifacts/tradewise_model_safe.pkl
ML_MODEL_ARTIFACT_NEUTRAL=artifacts/tradewise_model_neutral.pkl
ML_MODEL_ARTIFACT_RISKY=artifacts/tradewise_model_risky.pkl
ML_DEFAULT_ANNUAL_RATE=0.045
ML_BACKEND_HOST=127.0.0.1
ML_BACKEND_PORT=8000
ML_MARKET_DATA_PROVIDER=alpaca
ML_MARKET_DATA_INTERVAL=15m
ML_MARKET_DATA_ALPACA_FEED=delayed_sip

# MacBook backend -> desktop model server
# Set this only if the LLM runs on a different machine.
ML_QWEN_REMOTE_BASE_URL=
ML_QWEN_REMOTE_PROVIDER=ollama
ML_QWEN_REMOTE_API_KEY=
ML_QWEN_REMOTE_MODEL=auto
ML_QWEN_REMOTE_MODEL_SIMPLE=smallest
ML_QWEN_REMOTE_MODEL_COMPLEX=largest
ML_QWEN_REMOTE_TIMEOUT_SECONDS=60
ML_MARKET_BRIEF_CACHE_SECONDS=300
ML_PORTFOLIO_COACH_CACHE_SECONDS=600

# Local fallback model settings
ML_QWEN_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
ML_QWEN_LOCAL_ONLY=true
ML_QWEN_ALLOW_CPU=false
ML_QWEN_ALLOW_CHAT_CPU=true
ML_QWEN_QUANTIZE_CPU=true
ML_QWEN_INVESTMENT_CHAT_MAX_NEW_TOKENS=32

HF_TOKEN=
