# Copy to backend/.env and fill in secrets. Never commit backend/.env.
# Python loads backend/.env on import; dev.mjs also reads it for ML_BACKEND_PORT.

ML_MODEL_VERSION=dev

ML_MODEL_ARTIFACT=artifacts/tradewise_model.pkl
ML_MODEL_ARTIFACT_SAFE=artifacts/tradewise_model_safe.pkl
ML_MODEL_ARTIFACT_NEUTRAL=artifacts/tradewise_model_neutral.pkl
ML_MODEL_ARTIFACT_RISKY=artifacts/tradewise_model_risky.pkl

ML_DEFAULT_ANNUAL_RATE=0.045

# Used by scripts/dev.mjs and dev-backend.mjs
ML_BACKEND_HOST=127.0.0.1
ML_BACKEND_PORT=8000

# Market data (use yfinance for local dev without keys)
ML_MARKET_DATA_PROVIDER=alpaca
ML_MARKET_DATA_INTERVAL=15m
ML_MARKET_DATA_ALPACA_FEED=delayed_sip
ML_MARKET_DATA_ALPACA_KEY_ID=your_alpaca_key_id
ML_MARKET_DATA_ALPACA_SECRET_KEY=your_alpaca_secret_key

# Optional: APCA_* are accepted as aliases for the same keys
# APCA_API_KEY_ID=
# APCA_API_SECRET_KEY=

# Paper trading / live stream may also use ML_TRADING_ALPACA_* (see paper_trading.py, live_stream.py)
# ML_TRADING_ALPACA_KEY_ID=
# ML_TRADING_ALPACA_SECRET_KEY=

# Alpaca paper REST base URL is not read from env in this codebase; keys above are what matter.
